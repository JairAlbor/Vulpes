# Gemini API key (required)
GEMINI_API_KEY=YOUR_API_KEY_HERE

# Server
PORT=4000

# Cache refresh interval in days
CACHE_DAYS=7

# Crawler settings
CRAWLER_MAX_PAGES=150
CRAWLER_DELAY_MS=700

# Security (production)
# Comma-separated allowed origins for CORS (leave empty to reflect request origin)
# CORS_ORIGINS=https://www.colegio.umich.mx,https://colegio.umich.mx

# Rate limiting: max requests per IP per window
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=60000
MAX_BODY_BYTES=32768

# Optional: protect POST /api/actualizar-cache
# CACHE_UPDATE_TOKEN=your-secret-token-here
